---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Navbar from "~/components/Navbar.astro";
import Footer from "~/components/Footer.astro";
import { getDocsNav } from "~/data/docs-nav";
import { useTranslations } from "~/i18n/ui";

const lang = "zh" as const;
const t = useTranslations(lang);
const docsNav = getDocsNav(lang);
---

<BaseLayout title={t("page.docs.title")} description={t("page.docs.description")} lang={lang}>
  <Navbar variant="docs" lang={lang} />

  <section class="border-b border-line bg-paper/40 relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-40 pointer-events-none"></div>
    <div class="relative max-w-[1280px] mx-auto px-5 lg:px-8 py-14">
      <div class="caps text-ink-muted mb-2">{t("docs.index.kicker")}</div>
      <h1
        class="display text-[2.6rem] md:text-[3.2rem] leading-[1.05] tracking-tight max-w-[24ch]"
        set:html={t("docs.index.title.html")}
      ></h1>
      <p
        class="mt-4 max-w-[64ch] text-[16px] text-ink-muted leading-relaxed"
        set:html={t("docs.index.intro.html")}
      ></p>
    </div>
  </section>

  <div class="max-w-[1280px] mx-auto px-5 lg:px-8 py-12 space-y-12">
    {
      docsNav.map((section) => (
        <section>
          <h2 class="display text-[1.6rem] mb-4">{section.label}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {section.links.map((link) => (
              <a
                href={link.href}
                class="rounded-xl border border-line bg-canvas hover:bg-paper hover:border-line-strong transition-colors p-5 corner-anchor"
              >
                <div class="text-[15px] font-medium text-ink mb-1">{link.title}</div>
                {link.summary ? (
                  <div class="text-[13.5px] text-ink-muted leading-relaxed">{link.summary}</div>
                ) : null}
                <div class="mt-3 inline-flex items-center gap-1.5 text-[12px] text-klein-ink mono">
                  {t("docs.index.read")}
                  <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <Footer lang={lang} />
</BaseLayout>
