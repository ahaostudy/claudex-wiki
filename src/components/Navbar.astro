---
import Logo from "~/components/Logo.astro";
import {
  getLocaleFromUrl,
  localizePath,
  unlocalizePath,
  locales,
  localeLabels,
  localeShortLabels,
  htmlLang,
  type Locale,
} from "~/i18n/config";
import { useTranslations } from "~/i18n/ui";

interface Props {
  variant?: "marketing" | "docs";
  lang?: Locale;
}

const { lang: langProp } = Astro.props;
const lang = langProp ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonical = unlocalizePath(path) || "/";
const inDocs = canonical.startsWith("/docs");
const onIndex = canonical === "/" && !inDocs;

const homeHref = localizePath("/", lang);
const docsHref = localizePath("/docs", lang);
---

<header class="sticky top-0 z-40 bg-canvas/85 backdrop-blur-md border-b border-ink/15">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-10 h-12 flex items-center gap-4">
    <a href={homeHref} class="flex items-center gap-2.5 group" aria-label="claudex home">
      <Logo class="w-5 h-5" />
      <span class="mono text-[12px] tracking-tight">claudex</span>
    </a>

    <nav class="ml-auto flex items-center gap-6 md:gap-8">
      <a
        href={homeHref}
        class={"label-sm ed-link " + (onIndex ? "active" : "text-ink-muted")}
      >
        {t("nav.index")}
      </a>
      <a
        href={docsHref}
        class={"label-sm ed-link " + (inDocs ? "active" : "text-ink-muted")}
      >
        {t("nav.docs")}
      </a>
      <a
        href="https://github.com/ahaostudy/claudex"
        target="_blank"
        rel="noopener"
        class="label-sm ed-link text-ink-muted"
      >
        {t("nav.github")} <span aria-hidden="true">↗</span>
      </a>

      <div class="lang-dropdown" data-lang-dropdown>
        <button
          type="button"
          class="lang-trigger"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-label={t("lang.switcher.aria")}
        >
          <span class="label-sm">{localeShortLabels[lang]}</span>
          <svg
            class="lang-chev"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            aria-hidden="true"
          >
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <ul class="lang-menu" role="listbox" aria-label={t("lang.switcher.aria")} hidden>
          {
            locales.map((loc) => {
              const href = localizePath(canonical, loc as Locale);
              const isActive = loc === lang;
              return (
                <li role="presentation">
                  <a
                    href={href}
                    role="option"
                    hreflang={htmlLang[loc as Locale]}
                    aria-selected={isActive ? "true" : "false"}
                    class={"lang-item" + (isActive ? " active" : "")}
                  >
                    <span class="mono lang-short">{localeShortLabels[loc as Locale]}</span>
                    <span class="lang-full">{localeLabels[loc as Locale]}</span>
                    {isActive ? (
                      <svg
                        class="lang-check"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        aria-hidden="true"
                      >
                        <path d="M5 12l5 5 9-10" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    ) : null}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>

      <button
        type="button"
        data-theme-toggle
        class="theme-toggle"
        aria-label="Switch to dark theme"
        aria-pressed="false"
        title="Toggle theme"
      >
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .lang-dropdown {
    position: relative;
  }
  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    height: 2rem;
    padding: 0 0.5rem 0 0.65rem;
    border-radius: 6px;
    border: 1px solid rgb(var(--c-line));
    color: rgb(var(--c-ink-soft));
    background: transparent;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }
  .lang-trigger:hover,
  .lang-trigger[aria-expanded="true"] {
    border-color: rgb(var(--c-line-strong));
    background: rgb(var(--c-paper));
    color: rgb(var(--c-ink));
  }
  .lang-chev {
    width: 0.7rem;
    height: 0.7rem;
    transition: transform 180ms ease;
  }
  .lang-trigger[aria-expanded="true"] .lang-chev {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 11rem;
    margin: 0;
    padding: 0.3rem;
    list-style: none;
    background: rgb(var(--c-canvas));
    border: 1px solid rgb(var(--c-line-strong));
    border-radius: 8px;
    box-shadow: 0 12px 28px -12px rgb(0 0 0 / 0.18);
    z-index: 50;
  }
  .lang-menu[hidden] {
    display: none;
  }
  .lang-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    height: 2rem;
    padding: 0 0.6rem;
    border-radius: 5px;
    color: rgb(var(--c-ink-muted));
    text-decoration: none;
    transition:
      background-color 140ms ease,
      color 140ms ease;
  }
  .lang-item:hover,
  .lang-item:focus-visible {
    background: rgb(var(--c-paper));
    color: rgb(var(--c-ink));
    outline: none;
  }
  .lang-item.active {
    color: rgb(var(--c-ink));
  }
  .lang-short {
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: rgb(var(--c-ink-muted));
    min-width: 1.5rem;
    text-transform: uppercase;
  }
  .lang-item.active .lang-short {
    color: rgb(var(--c-klein));
  }
  .lang-full {
    font-size: 13px;
    line-height: 1;
  }
  .lang-check {
    width: 0.85rem;
    height: 0.85rem;
    margin-left: auto;
    color: rgb(var(--c-klein));
  }
</style>

<script is:inline>
  document.querySelectorAll("[data-lang-dropdown]").forEach((root) => {
    const trigger = root.querySelector(".lang-trigger");
    const menu = root.querySelector(".lang-menu");
    if (!trigger || !menu) return;

    const close = () => {
      trigger.setAttribute("aria-expanded", "false");
      menu.setAttribute("hidden", "");
    };
    const open = () => {
      trigger.setAttribute("aria-expanded", "true");
      menu.removeAttribute("hidden");
    };

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const expanded = trigger.getAttribute("aria-expanded") === "true";
      if (expanded) close();
      else open();
    });

    document.addEventListener("click", (e) => {
      if (!root.contains(e.target)) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        close();
        trigger.focus();
      }
    });
  });
</script>
