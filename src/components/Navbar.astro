---
import Logo from "~/components/Logo.astro";
import {
  getLocaleFromUrl,
  localizePath,
  unlocalizePath,
  locales,
  localeShortLabels,
  defaultLocale,
  type Locale,
} from "~/i18n/config";
import { useTranslations } from "~/i18n/ui";

interface Props {
  variant?: "marketing" | "docs";
  lang?: Locale;
}

const { lang: langProp } = Astro.props;
const lang = langProp ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonical = unlocalizePath(path) || "/";
const inDocs = canonical.startsWith("/docs");
const onIndex = canonical === "/" && !inDocs;

const homeHref = localizePath("/", lang);
const docsHref = localizePath("/docs", lang);
---

<header class="sticky top-0 z-40 bg-canvas/85 backdrop-blur-md border-b border-ink/15">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-10 h-12 flex items-center gap-4">
    <a href={homeHref} class="flex items-center gap-2.5 group" aria-label="claudex home">
      <Logo class="w-5 h-5" />
      <span class="mono text-[12px] tracking-tight">claudex</span>
    </a>

    <span class="hidden md:inline-block w-px h-4 bg-ink/15"></span>
    <span class="hidden md:inline-block label text-ink-muted">{t("nav.edition")}</span>

    <nav class="ml-auto flex items-center gap-6 md:gap-8">
      <a
        href={homeHref}
        class={"label-sm ed-link " + (onIndex ? "active" : "text-ink-muted")}
      >
        {t("nav.index")}
      </a>
      <a
        href={docsHref}
        class={"label-sm ed-link " + (inDocs ? "active" : "text-ink-muted")}
      >
        {t("nav.docs")}
      </a>
      <a
        href="https://github.com/ahaostudy/claudex"
        target="_blank"
        rel="noopener"
        class="label-sm ed-link text-ink-muted"
      >
        {t("nav.github")} <span aria-hidden="true">↗</span>
      </a>

      <div class="lang-switch flex items-center" aria-label={t("lang.switcher.aria")}>
        {
          locales.map((loc, i) => {
            const href = localizePath(canonical, loc as Locale);
            const isActive = loc === lang;
            return (
              <>
                {i > 0 ? <span class="text-ink-faint mx-1.5" aria-hidden="true">·</span> : null}
                <a
                  href={href}
                  hreflang={loc === defaultLocale ? "en" : "zh-CN"}
                  class={"label-sm transition-colors " + (isActive ? "text-ink font-medium" : "text-ink-muted hover:text-ink")}
                  aria-current={isActive ? "true" : undefined}
                >
                  {localeShortLabels[loc as Locale]}
                </a>
              </>
            );
          })
        }
      </div>

      <button
        type="button"
        data-theme-toggle
        class="theme-toggle"
        aria-label="Switch to dark theme"
        aria-pressed="false"
        title="Toggle theme"
      >
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>
