---
interface Props {
  variant?: "marketing" | "docs";
}

const { variant = "marketing" } = Astro.props;

const navLinks = [
  { href: "/#features", label: "Features" },
  { href: "/#showcase", label: "Showcase" },
  { href: "/#architecture", label: "Architecture" },
  { href: "/#install", label: "Install" },
];
---

<header class="sticky top-0 z-40 bg-canvas/85 backdrop-blur-md border-b border-line">
  <div class="max-w-[1280px] mx-auto px-5 lg:px-8 h-14 flex items-center gap-3">
    <a href="/" class="flex items-center gap-2 group">
      <svg viewBox="0 0 32 32" class="w-5 h-5">
        <path d="M9 22 L16 8 L23 22 Z" fill="#cc785c"></path>
        <circle cx="16" cy="18" r="2.2" fill="#faf9f5"></circle>
      </svg>
      <span class="mono text-[13px] tracking-tight">claudex</span>
      <span class="hidden sm:inline-flex pill"><span class="dot"></span>self-hosted</span>
    </a>

    {
      variant === "marketing" ? (
        <nav class="hidden md:flex items-center gap-1 ml-6">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 h-8 inline-flex items-center rounded-md hover:bg-paper text-[13px] text-ink-soft transition-colors"
            >
              {link.label}
            </a>
          ))}
          <a
            href="/docs"
            class="px-3 h-8 inline-flex items-center rounded-md hover:bg-paper text-[13px] text-ink-soft transition-colors"
          >
            Docs
          </a>
        </nav>
      ) : (
        <nav class="hidden md:flex items-center gap-1 ml-6">
          <a
            href="/"
            class="px-3 h-8 inline-flex items-center rounded-md hover:bg-paper text-[13px] text-ink-soft transition-colors"
          >
            Home
          </a>
          <a
            href="/docs"
            class="px-3 h-8 inline-flex items-center rounded-md bg-paper text-[13px] text-ink font-medium"
          >
            Docs
          </a>
        </nav>
      )
    }

    <div class="ml-auto flex items-center gap-2">
      <a
        href="https://github.com/ahaostudy/claudex"
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
        class="hidden sm:inline-flex items-center gap-2 h-8 px-3 rounded-md border border-line hover:border-line-strong hover:bg-paper text-[12.5px] text-ink-soft transition-colors"
      >
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18a10.94 10.94 0 015.74 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56 4.57-1.52 7.85-5.83 7.85-10.91C23.5 5.65 18.35.5 12 .5z"
          />
        </svg>
        <span class="mono">GitHub</span>
      </a>
      <a
        href="/docs/installation"
        class="inline-flex items-center gap-1.5 h-8 px-3 rounded-md bg-ink text-canvas hover:bg-ink-soft text-[12.5px] font-medium transition-colors"
      >
        Get started
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</header>
