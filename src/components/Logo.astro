---
/**
 * claudex brand mark — "Portal Pebble".
 *
 * Asymmetric closed loop stroked with an ink → Claude-coral gradient.
 * Mirrors web/public/icon.svg structurally, but the dark stop reads
 * `currentColor` so the mark stays legible against any background:
 *   - light theme → near-black on warm white (the canonical look)
 *   - dark theme  → warm white on near-black (auto-inverted via currentColor)
 *
 * The klein-orange end-stop is fixed and does the brand work in both.
 *
 * Each instance gets a unique gradient id so multiple logos on the same
 * page don't fight over a shared `#g` reference.
 */
interface Props {
  class?: string;
}
const { class: className = "w-5 h-5" } = Astro.props;
const gradId = `logo-${Math.random().toString(36).slice(2, 9)}`;
---

<svg viewBox="0 0 1024 1024" class={`text-ink ${className}`} aria-hidden="true">
  <defs>
    <linearGradient id={gradId} x1="0.1" y1="0.1" x2="0.9" y2="0.9">
      <stop offset="0%" stop-color="currentColor"></stop>
      <stop offset="100%" stop-color="#CC785C"></stop>
    </linearGradient>
  </defs>
  <path
    d="M 512 200 C 300 210, 200 380, 220 560 C 240 740, 460 830, 660 770 C 840 710, 880 480, 780 320 C 700 210, 620 200, 512 200 Z"
    fill="none"
    stroke={`url(#${gradId})`}
    stroke-width="100"
    stroke-linecap="round"
    stroke-linejoin="round"
  ></path>
</svg>
