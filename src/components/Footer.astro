---
import Logo from "~/components/Logo.astro";
import { getLocaleFromUrl, localizePath, type Locale } from "~/i18n/config";
import { useTranslations } from "~/i18n/ui";

interface Props {
  lang?: Locale;
}

const lang = Astro.props.lang ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-canvas border-t border-ink/15">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-10 py-10 grid grid-cols-12 gap-6 items-center">
    <div class="col-span-12 md:col-span-4 flex items-center gap-3">
      <Logo class="w-6 h-6" />
      <div class="flex flex-col">
        <span class="mono text-[12px] text-ink">claudex</span>
        <span class="label-sm text-ink-muted">© {year}</span>
      </div>
    </div>

    <nav class="col-span-12 md:col-span-5 flex flex-wrap items-center gap-x-6 gap-y-2 md:justify-center">
      <a href={localizePath("/", lang)} class="label-sm ed-link text-ink-muted">{t("footer.index")}</a>
      <a href={localizePath("/docs", lang)} class="label-sm ed-link text-ink-muted">{t("footer.docs")}</a>
      <a href={localizePath("/docs/installation", lang)} class="label-sm ed-link text-ink-muted">{t("footer.install")}</a>
      <a
        href="https://github.com/ahaostudy/claudex"
        target="_blank"
        rel="noopener"
        class="label-sm ed-link text-ink-muted"
      >
        GitHub <span aria-hidden="true">↗</span>
      </a>
    </nav>

    <div class="col-span-12 md:col-span-3 md:text-right">
      <span class="label-sm text-ink-muted">{t("footer.legal")}</span>
    </div>
  </div>
</footer>
