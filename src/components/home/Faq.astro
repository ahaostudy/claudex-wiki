---
const faqs = [
  {
    q: "Is claudex an alternative to Claude Code?",
    a: 'No — claudex is a *driver* for Claude Code. It runs the real <span class="mono">claude</span> CLI as a subprocess via the Agent SDK, so all of your existing config, MCP servers, plugins, and credentials are inherited automatically. We do not call the Anthropic API directly.',
  },
  {
    q: "Does claudex see my prompts or my code?",
    a: "Only locally — the server runs on your machine, talks to your local <span class=\"mono\">claude</span> subprocess, and streams structured events to your browser. There's no telemetry, no analytics, no outbound traffic from claudex itself.",
  },
  {
    q: "How is it secured?",
    a: 'Username + password + TOTP at first sign-in. JWT in an httpOnly cookie. Ten single-use recovery codes printed once at init. The server refuses to bind anything other than <span class="mono">127.0.0.1</span> — public exposure is your tunnel of choice.',
  },
  {
    q: "Can I run it on a server, not my laptop?",
    a: "Yes — anywhere the <span class=\"mono\">claude</span> CLI runs. The most common setups are: (1) on your dev laptop, exposed to your phone over a tunnel; (2) on a small VPS or NAS that has the CLI configured; (3) inside a tmux on a remote dev box you SSH into.",
  },
  {
    q: "Mobile-first, but does it work on desktop?",
    a: "Every screen is designed for a 390 px viewport first, then adaptively expanded — chat opens into a three-column cockpit on a wide screen, the diff review picks up split-pane mode, the sessions rail becomes a permanent sidebar.",
  },
  {
    q: "Where does my data live?",
    a: 'Everything is in <span class="mono">~/.claudex/</span> — SQLite DB, logs, JWT secret. Backup is a single JSON bundle from the Settings panel. claudex never writes to <span class="mono">~/.claude/</span>; that belongs to the CLI.',
  },
];
---

<section id="faq" class="border-b border-line">
  <div class="max-w-[1280px] mx-auto px-5 lg:px-10 py-20 lg:py-24">
    <div class="flex items-baseline gap-4 mb-3 flex-wrap">
      <span class="mono text-[12px] text-ink-faint">section · 05</span>
      <h2 class="display text-[2rem] md:text-[2.4rem] leading-tight">Honest answers</h2>
    </div>
    <p class="max-w-[68ch] text-[15px] text-ink-muted">
      What claudex is, what it isn't, and how it stays out of your way.
    </p>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-3">
      {
        faqs.map((f, i) => (
          <details class="group rounded-xl border border-line bg-canvas open:bg-paper/60 open:border-line-strong transition-colors">
            <summary class="cursor-pointer list-none px-5 py-4 flex items-start gap-3">
              <span class="mono text-[11px] text-ink-faint pt-0.5">{String(i + 1).padStart(2, "0")}</span>
              <span class="flex-1 text-[14.5px] font-medium text-ink leading-snug">{f.q}</span>
              <span class="text-ink-muted group-open:rotate-45 transition-transform">
                <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M12 5v14M5 12h14" stroke-linecap="round" />
                </svg>
              </span>
            </summary>
            <div class="px-5 pb-5 -mt-1 pl-12 text-[14px] text-ink-muted leading-relaxed" set:html={f.a} />
          </details>
        ))
      }
    </div>
  </div>
</section>
