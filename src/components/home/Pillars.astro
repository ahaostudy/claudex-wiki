---
/**
 * Pillars — what makes claudex different, in 4 rows.
 *
 * Two-column rows: serif title + label kicker on the left, serif body on
 * the right, hairline between rows. The hover-reveal klein bar on the
 * left edge gives just enough motion without turning into magazine chrome.
 */
import { getLocaleFromUrl, localizePath, type Locale } from "~/i18n/config";
import { useTranslations } from "~/i18n/ui";

interface Props {
  lang?: Locale;
}

const lang = Astro.props.lang ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const pillars = (["01", "02", "03", "04"] as const).map((no) => ({
  title: t(`pillars.${no}.title`),
  kicker: t(`pillars.${no}.kicker`),
  body: t(`pillars.${no}.body`),
}));

const introHtml = t("pillars.intro.html", { docs: localizePath("/docs", lang) });
---

<section
  id="pillars"
  class="relative bg-paper/40 border-b border-ink/15"
  aria-label="What makes claudex different"
>
  <div class="max-w-[1440px] mx-auto px-6 lg:px-10 pt-24 pb-16 lg:pt-32 lg:pb-24">
    <!-- Section header -->
    <div class="grid grid-cols-12 gap-6 items-end mb-16 lg:mb-20">
      <div class="col-span-12 lg:col-span-6">
        <h2 class="display text-[clamp(2.4rem,5vw,4.5rem)] leading-[0.95] tracking-[-0.03em] max-w-[18ch]">
          {t("pillars.title.lead")} <span class="display-italic text-klein">{t("pillars.title.italic")}</span>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-5 lg:col-start-8">
        <p class="text-[14.5px] leading-[1.65] text-ink-muted max-w-[42ch]" set:html={introHtml}></p>
      </div>
    </div>

    <!-- List -->
    <ol class="border-t border-ink/15 list-none p-0">
      {
        pillars.map((p, i) => (
          <li class={"group relative grid grid-cols-12 gap-x-6 gap-y-3 lg:gap-y-0 py-8 lg:py-10 border-b " + (i === pillars.length - 1 ? "border-ink/15" : "border-ink/15")}>
            <span class="absolute left-0 top-0 bottom-0 w-px bg-klein scale-y-0 origin-top group-hover:scale-y-100 transition-transform duration-500 ease-out" aria-hidden="true"></span>

            <!-- Title + kicker -->
            <div class="col-span-12 lg:col-span-5 flex flex-col gap-2.5">
              <h3 class="display text-[clamp(1.4rem,2.2vw,2rem)] leading-[1.1] tracking-[-0.02em] text-ink">
                {p.title}
              </h3>
              <div class="label text-ink-muted">{p.kicker}</div>
            </div>

            <!-- Body -->
            <div class="col-span-12 lg:col-span-6 lg:col-start-7 flex items-start">
              <p class="prose-serif text-[15px] leading-[1.65] text-ink-soft max-w-[48ch]">
                {p.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
