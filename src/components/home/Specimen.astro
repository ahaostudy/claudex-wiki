<style>
  /* Fixed-aspect, container-query-scaled desktop preview.
     The stage renders at the natural design size (1280×800) regardless
     of viewport — the frame's aspect-ratio reserves matching space, and
     the stage is scaled by `100cqi / 1280` so it always exactly fills
     the frame width-wise. On a 390px phone this becomes a perfect
     ~390×244 miniature instead of a squashed grid. */
  .desktop-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 1280 / 800;
    container-type: inline-size;
  }
  .desktop-stage {
    position: absolute;
    top: 0;
    left: 0;
    width: 1280px;
    height: 800px;
    transform-origin: top left;
    transform: scale(calc(100cqi / 1280));
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    scrollbar-width: none;
  }
</style>
