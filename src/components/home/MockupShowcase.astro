---
/**
 * MockupShowcase
 *
 * Three hand-drawn UI mockups in claudex's house style (no real screenshots).
 * Two iPhone frames flanking a desktop cockpit, all using the same Tailwind
 * tokens as the real app. Static — no JS — so they ship as plain HTML.
 */
---

<section id="showcase" class="border-b border-line bg-paper/40 relative overflow-hidden">
  <div class="absolute inset-0 bg-grid opacity-40 pointer-events-none"></div>
  <div class="relative max-w-[1280px] mx-auto px-5 lg:px-10 py-20 lg:py-28">
    <div class="flex items-baseline gap-4 mb-3 flex-wrap">
      <span class="mono text-[12px] text-ink-faint">section · 02</span>
      <h2 class="display text-[2rem] md:text-[2.4rem] leading-tight">Designed for thumb and trackpad alike</h2>
    </div>
    <p class="max-w-[68ch] text-[15px] text-ink-muted">
      A long Claude session, three live surfaces. The transcript and permission card on a phone, the same conversation
      opened up into a three-column cockpit on the desktop.
    </p>

    <div class="mt-14 grid grid-cols-1 xl:grid-cols-[auto_1fr_auto] items-start gap-8 xl:gap-10 justify-items-center">
      <!-- Phone 1 — Chat with inline permission prompt -->
      <div class="flex flex-col items-center gap-3">
        <div class="caps text-ink-muted">Phone · chat + permission</div>
        <div class="iphone">
          <div class="iphone-inner">
            <div class="iphone-island"></div>
            <div class="iphone-status">
              <span class="mono">9:41</span>
              <span class="flex items-center gap-1">
                <span class="h-2 w-3.5 bg-ink rounded-sm"></span>
                <span class="mono text-[10px]">5G</span>
                <span class="h-2 w-4 border border-ink rounded-sm flex items-center justify-end pr-[1px]">
                  <span class="h-1 w-3 bg-ink rounded-[1px]"></span>
                </span>
              </span>
            </div>
            <div class="iphone-home"></div>

            <div class="iphone-content flex flex-col bg-canvas">
              <!-- Header -->
              <div class="px-4 pt-3 pb-2 border-b border-line bg-canvas/95 backdrop-blur flex items-center gap-2">
                <button aria-label="back" class="w-7 h-7 inline-flex items-center justify-center rounded-md hover:bg-paper">
                  <svg viewBox="0 0 24 24" class="w-4 h-4 text-ink-soft" fill="none" stroke="currentColor" stroke-width="1.7">
                    <path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </button>
                <div class="flex-1 min-w-0">
                  <div class="text-[12.5px] font-medium leading-tight truncate">refactor the auth middleware</div>
                  <div class="mono text-[10px] text-ink-muted truncate">claudex / main · 47 turns</div>
                </div>
                <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-success-wash text-success text-[10px] font-medium">
                  <span class="h-1.5 w-1.5 rounded-full bg-success"></span>live
                </span>
              </div>

              <!-- Transcript -->
              <div class="flex-1 overflow-hidden px-3 py-3 space-y-3 text-[12.5px]">
                <div class="rounded-md bg-paper border border-line px-3 py-2">
                  <div class="caps text-ink-muted mb-0.5">you · 9:42</div>
                  <div class="text-ink-soft leading-relaxed">
                    rip out the old session token storage and replace it with the JWT helper in lib/auth.
                  </div>
                </div>

                <div class="space-y-2">
                  <div class="caps text-ink-muted">claude · plan</div>
                  <div class="rounded-md bg-canvas border border-line px-3 py-2 text-ink-soft leading-relaxed">
                    <ol class="space-y-1 list-decimal pl-4">
                      <li>read <span class="mono text-ink">server/src/auth/middleware.ts</span></li>
                      <li>grep for <span class="mono text-ink">setSessionToken</span></li>
                      <li>swap to <span class="mono text-ink">signJwt</span></li>
                      <li>run <span class="mono text-ink">pnpm test auth</span></li>
                    </ol>
                  </div>
                </div>

                <!-- Permission card -->
                <div class="rounded-lg border border-klein bg-klein-wash/70 px-3 py-2.5 shadow-card">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class="inline-flex items-center justify-center w-5 h-5 rounded bg-klein text-canvas">
                      <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.4">
                        <circle cx="8" cy="14" r="4"></circle>
                        <path d="M11 13l9-9M16 8l3 3" stroke-linecap="round"></path>
                      </svg>
                    </span>
                    <div class="caps text-klein-ink">needs your approval</div>
                  </div>
                  <div class="text-[12px] font-medium text-ink leading-snug">
                    Edit <span class="mono">server/src/auth/middleware.ts</span>
                  </div>
                  <div class="mt-1 text-[11.5px] text-ink-muted leading-relaxed">
                    <span class="mono text-success">+34</span>
                    <span class="mono text-danger ml-1">−18</span>
                    · 1 file · scoped to repo
                  </div>
                  <div class="mt-2 grid grid-cols-2 gap-1.5">
                    <button class="h-8 rounded-md bg-ink text-canvas text-[12px] font-medium">Allow once</button>
                    <button class="h-8 rounded-md border border-line-strong bg-canvas text-[12px] text-ink-soft">Review diff</button>
                  </div>
                </div>

                <!-- thinking dots -->
                <div class="flex items-center gap-1.5 px-1 pt-1">
                  <span class="h-1.5 w-1.5 rounded-full bg-klein thinking-dot"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-klein thinking-dot"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-klein thinking-dot"></span>
                  <span class="caps text-ink-muted ml-1">claude is thinking</span>
                </div>
              </div>

              <!-- Composer -->
              <div class="border-t border-line p-2 flex items-center gap-2">
                <div class="flex-1 h-9 rounded-full border border-line bg-paper px-3 flex items-center text-[12px] text-ink-faint">
                  Reply or queue a follow-up…
                </div>
                <button class="w-9 h-9 rounded-full bg-ink text-canvas inline-flex items-center justify-center">
                  <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12l14-7-5 14-3-6-6-1z" stroke-linejoin="round"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop -->
      <div class="w-full max-w-[860px] flex flex-col items-center gap-3">
        <div class="caps text-ink-muted">Desktop · three-column cockpit</div>
        <div class="desktop">
          <div class="desktop-chrome">
            <span class="dot" style="background:#ff5f57"></span>
            <span class="dot" style="background:#febc2e"></span>
            <span class="dot" style="background:#28c840"></span>
            <span class="ml-3 mono text-[10.5px] text-canvas/70">claudex.local — 127.0.0.1:5179/session/47</span>
          </div>
          <div class="desktop-inner h-[520px] grid grid-cols-[200px_1fr_240px]">
            <!-- Sessions rail -->
            <aside class="border-r border-line bg-paper/60 flex flex-col">
              <div class="px-3 py-2.5 border-b border-line flex items-center gap-2">
                <svg viewBox="0 0 32 32" class="w-3.5 h-3.5">
                  <path d="M9 22 L16 8 L23 22 Z" fill="#cc785c"></path>
                  <circle cx="16" cy="18" r="2.2" fill="#faf9f5"></circle>
                </svg>
                <span class="mono text-[11px]">claudex</span>
                <span class="ml-auto inline-flex items-center gap-1 mono text-[10px] text-success">
                  <span class="h-1.5 w-1.5 rounded-full bg-success"></span>live
                </span>
              </div>
              <div class="px-3 py-2 border-b border-line">
                <div class="h-7 rounded-md border border-line bg-canvas flex items-center px-2 gap-1.5 text-[11px] text-ink-faint">
                  <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="1.8">
                    <circle cx="11" cy="11" r="6.5"></circle>
                    <path d="M16 16l4 4" stroke-linecap="round"></path>
                  </svg>
                  Search… <span class="ml-auto mono text-[9px] border border-line-strong rounded px-1">⌘K</span>
                </div>
              </div>
              <div class="flex-1 overflow-hidden">
                <div class="px-3 py-1.5 caps text-ink-muted">today</div>
                <button class="w-full text-left px-3 py-2 border-l-2 border-klein bg-canvas">
                  <div class="text-[12px] font-medium truncate">refactor auth middleware</div>
                  <div class="mono text-[10px] text-ink-muted">47 turns · live</div>
                </button>
                <button class="w-full text-left px-3 py-2 border-l-2 border-transparent hover:bg-paper">
                  <div class="text-[12px] truncate">drop the legacy hero image</div>
                  <div class="mono text-[10px] text-ink-faint">12 turns · idle</div>
                </button>
                <button class="w-full text-left px-3 py-2 border-l-2 border-transparent hover:bg-paper">
                  <div class="text-[12px] truncate">windows pm2 popup loop</div>
                  <div class="mono text-[10px] text-ink-faint">31 turns · archived</div>
                </button>
                <div class="px-3 py-1.5 caps text-ink-muted mt-2">yesterday</div>
                <button class="w-full text-left px-3 py-2 border-l-2 border-transparent hover:bg-paper">
                  <div class="text-[12px] truncate">cross-platform abs path</div>
                  <div class="mono text-[10px] text-ink-faint">22 turns</div>
                </button>
                <button class="w-full text-left px-3 py-2 border-l-2 border-transparent hover:bg-paper">
                  <div class="text-[12px] truncate">hot-swap model on live SDK</div>
                  <div class="mono text-[10px] text-ink-faint">18 turns</div>
                </button>
              </div>
              <div class="border-t border-line px-3 py-2 flex items-center gap-2">
                <div class="w-6 h-6 rounded-full bg-klein text-canvas mono text-[10px] inline-flex items-center justify-center">H</div>
                <div class="text-[11px] leading-tight">
                  <div class="text-ink">haowu</div>
                  <div class="mono text-[9.5px] text-ink-faint">mbp-16.home</div>
                </div>
              </div>
            </aside>

            <!-- Transcript -->
            <main class="flex flex-col min-w-0">
              <div class="px-4 py-2.5 border-b border-line flex items-center gap-2">
                <div class="flex-1 min-w-0">
                  <div class="text-[12.5px] font-medium truncate">refactor the auth middleware</div>
                  <div class="mono text-[10px] text-ink-muted">claude/auth-middleware · 47 turns · sonnet 4.6</div>
                </div>
                <button class="h-6 px-2 rounded border border-line text-[10.5px] text-ink-soft hover:bg-paper">view</button>
                <button class="h-6 px-2 rounded border border-line text-[10.5px] text-ink-soft hover:bg-paper">tags</button>
              </div>

              <div class="flex-1 overflow-hidden px-4 py-4 space-y-3 text-[12.5px]">
                <div class="rounded-md bg-paper border border-line px-3 py-2 max-w-[80%]">
                  <div class="caps text-ink-muted mb-1">you · 9:42</div>
                  <div class="text-ink-soft leading-relaxed">
                    rip out the old session token storage and replace it with the JWT helper in lib/auth.
                  </div>
                </div>

                <div class="rounded-md border border-line bg-canvas px-3 py-2">
                  <div class="caps text-klein-ink mb-1.5">tool · grep</div>
                  <div class="mono text-[11px] text-ink-soft">
                    <span class="text-ink-faint">$</span> grep -rn "setSessionToken" server/src
                  </div>
                  <div class="mt-1 mono text-[10.5px] text-ink-muted leading-relaxed">
                    server/src/auth/middleware.ts:42<br />
                    server/src/auth/routes.ts:18<br />
                    server/src/lib/session.ts:91
                  </div>
                </div>

                <div class="rounded-md border border-success/30 bg-success-wash/60 px-3 py-2">
                  <div class="caps text-success mb-1">tool · edit</div>
                  <div class="mono text-[11px] text-ink-soft">
                    server/src/auth/middleware.ts
                  </div>
                  <div class="mt-1.5 grid grid-cols-[auto_1fr] gap-x-2 mono text-[10.5px] leading-tight">
                    <span class="text-ink-faint">42</span><span class="text-danger">- setSessionToken(reply, token)</span>
                    <span class="text-ink-faint">42</span><span class="text-success">+ const jwt = signJwt(payload)</span>
                    <span class="text-ink-faint">43</span><span class="text-success">+ reply.setCookie(JWT_COOKIE, jwt, COOKIE_OPTS)</span>
                  </div>
                </div>

                <div class="flex items-center gap-1.5 pt-1">
                  <span class="h-1.5 w-1.5 rounded-full bg-klein thinking-dot"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-klein thinking-dot"></span>
                  <span class="h-1.5 w-1.5 rounded-full bg-klein thinking-dot"></span>
                  <span class="caps text-ink-muted ml-1">running tests</span>
                </div>
              </div>

              <div class="border-t border-line p-2.5 flex items-center gap-2">
                <div class="flex-1 h-9 rounded-md border border-line bg-paper px-3 flex items-center text-[12px] text-ink-faint">
                  Queue a follow-up… <span class="ml-auto mono text-[10px]">⌘↵</span>
                </div>
              </div>
            </main>

            <!-- Subagents panel -->
            <aside class="border-l border-line bg-paper/60 flex flex-col">
              <div class="px-3 py-2.5 border-b border-line flex items-center gap-2">
                <span class="caps text-ink-muted">subagents</span>
                <span class="ml-auto mono text-[10px] text-ink-faint">3</span>
              </div>
              <div class="flex-1 overflow-hidden p-2.5 space-y-2">
                <div class="rounded-md border border-line bg-canvas p-2.5">
                  <div class="flex items-center gap-1.5 mb-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-klein"></span>
                    <span class="caps text-klein-ink">running</span>
                  </div>
                  <div class="text-[12px] font-medium leading-tight">grep auth references</div>
                  <div class="mono text-[10px] text-ink-muted mt-0.5">12 files scanned</div>
                </div>
                <div class="rounded-md border border-line bg-canvas p-2.5">
                  <div class="flex items-center gap-1.5 mb-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-success"></span>
                    <span class="caps text-success">done</span>
                  </div>
                  <div class="text-[12px] font-medium leading-tight">read middleware.ts</div>
                  <div class="mono text-[10px] text-ink-muted mt-0.5">142 lines</div>
                </div>
                <div class="rounded-md border border-line bg-canvas p-2.5">
                  <div class="flex items-center gap-1.5 mb-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-warn"></span>
                    <span class="caps text-warn">queued</span>
                  </div>
                  <div class="text-[12px] font-medium leading-tight">pnpm test auth</div>
                  <div class="mono text-[10px] text-ink-muted mt-0.5">waits on edit</div>
                </div>

                <div class="mt-3 caps text-ink-muted">usage · this session</div>
                <div class="rounded-md border border-line bg-canvas p-2.5">
                  <div class="flex items-baseline justify-between">
                    <div>
                      <div class="display text-[18px] leading-none">12.4k</div>
                      <div class="mono text-[10px] text-ink-muted mt-0.5">tokens in</div>
                    </div>
                    <div class="text-right">
                      <div class="display text-[18px] leading-none">3.2k</div>
                      <div class="mono text-[10px] text-ink-muted mt-0.5">tokens out</div>
                    </div>
                  </div>
                  <div class="mt-2 h-1.5 w-full rounded-full bg-paper overflow-hidden">
                    <div class="h-full w-[35%] bg-klein rounded-full"></div>
                  </div>
                  <div class="mono text-[9.5px] text-ink-faint mt-1">35% of context</div>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </div>

      <!-- Phone 2 — Diff review -->
      <div class="flex flex-col items-center gap-3">
        <div class="caps text-ink-muted">Phone · diff review</div>
        <div class="iphone">
          <div class="iphone-inner">
            <div class="iphone-island"></div>
            <div class="iphone-status">
              <span class="mono">9:43</span>
              <span class="flex items-center gap-1">
                <span class="h-2 w-3.5 bg-ink rounded-sm"></span>
                <span class="mono text-[10px]">5G</span>
                <span class="h-2 w-4 border border-ink rounded-sm flex items-center justify-end pr-[1px]">
                  <span class="h-1 w-3 bg-ink rounded-[1px]"></span>
                </span>
              </span>
            </div>
            <div class="iphone-home"></div>

            <div class="iphone-content flex flex-col bg-canvas">
              <!-- Header -->
              <div class="px-4 pt-3 pb-2 border-b border-line bg-canvas/95 backdrop-blur flex items-center gap-2">
                <button class="w-7 h-7 inline-flex items-center justify-center rounded-md hover:bg-paper">
                  <svg viewBox="0 0 24 24" class="w-4 h-4 text-ink-soft" fill="none" stroke="currentColor" stroke-width="1.7">
                    <path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </button>
                <div class="flex-1 min-w-0">
                  <div class="text-[12px] font-medium truncate">middleware.ts</div>
                  <div class="mono text-[10px] text-ink-muted truncate">1 of 3 · server/src/auth</div>
                </div>
                <span class="mono text-[10.5px] text-success">+34</span>
                <span class="mono text-[10.5px] text-danger">−18</span>
              </div>

              <!-- Tabs -->
              <div class="px-4 py-1.5 border-b border-line flex gap-1 text-[11px]">
                <button class="px-2 py-1 rounded-md bg-paper text-ink font-medium">Diff</button>
                <button class="px-2 py-1 rounded-md text-ink-muted">Side-by-side</button>
                <button class="px-2 py-1 rounded-md text-ink-muted">Comments <span class="mono text-[9px]">2</span></button>
              </div>

              <!-- Diff body -->
              <div class="flex-1 overflow-hidden bg-paper">
                <div class="mono text-[10.5px] leading-[1.55]">
                  <div class="px-4 py-1 bg-paper text-ink-faint border-b border-line">@@ -38,12 +38,16 @@</div>
                  <div class="grid grid-cols-[28px_1fr] hover:bg-canvas/60">
                    <span class="text-right pr-2 text-ink-faint">38</span>
                    <span class="px-2 text-ink-soft">async function applyAuth(req, reply) {</span>
                  </div>
                  <div class="grid grid-cols-[28px_1fr] bg-danger/[0.06]">
                    <span class="text-right pr-2 text-danger">39</span>
                    <span class="px-2 text-danger">  const token = getSessionToken(req)</span>
                  </div>
                  <div class="grid grid-cols-[28px_1fr] bg-danger/[0.06]">
                    <span class="text-right pr-2 text-danger">40</span>
                    <span class="px-2 text-danger">  if (!token) return reply.code(401)</span>
                  </div>
                  <div class="grid grid-cols-[28px_1fr] bg-danger/[0.06]">
                    <span class="text-right pr-2 text-danger">41</span>
                    <span class="px-2 text-danger">  setSessionToken(reply, token)</span>
                  </div>
                  <div class="grid grid-cols-[28px_1fr] bg-success/[0.07]">
                    <span class="text-right pr-2 text-success">39</span>
                    <span class="px-2 text-success">  const claims = verifyJwt(req)</span>
                  </div>
                  <div class="grid grid-cols-[28px_1fr] bg-success/[0.07]">
                    <span class="text-right pr-2 text-success">40</span>
                    <span class="px-2 text-success">  if (!claims) return reply.code(401)</span>
                  </div>
                  <div class="grid grid-cols-[28px_1fr] bg-success/[0.07]">
                    <span class="text-right pr-2 text-success">41</span>
                    <span class="px-2 text-success">  const jwt = signJwt(claims)</span>
                  </div>
                  <div class="grid grid-cols-[28px_1fr] bg-success/[0.07]">
                    <span class="text-right pr-2 text-success">42</span>
                    <span class="px-2 text-success">  reply.setCookie(JWT_COOKIE, jwt, COOKIE_OPTS)</span>
                  </div>

                  <!-- inline comment -->
                  <div class="mx-2 my-1.5 rounded-md border border-klein/30 bg-klein-wash px-2.5 py-1.5">
                    <div class="caps text-klein-ink mb-0.5 text-[8.5px]">your comment</div>
                    <div class="text-[11px] leading-snug text-ink-soft">
                      use COOKIE_OPTS_STRICT here — sessions hit api.* and we want SameSite=strict.
                    </div>
                  </div>
                </div>
              </div>

              <!-- Action bar -->
              <div class="border-t border-line p-2 flex items-center gap-2">
                <button class="flex-1 h-9 rounded-md border border-success/40 bg-success-wash text-success text-[12px] font-medium">
                  Accept
                </button>
                <button class="flex-1 h-9 rounded-md border border-line bg-canvas text-ink-soft text-[12px]">
                  Reject
                </button>
                <button class="w-9 h-9 rounded-md border border-line bg-canvas inline-flex items-center justify-center">
                  <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 text-ink-soft" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M21 15a4 4 0 01-4 4H8l-5 4V7a4 4 0 014-4h10a4 4 0 014 4v8z" stroke-linejoin="round"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
