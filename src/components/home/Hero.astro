---
/**
 * Hero — editorial cover spread.
 *
 * Premise: this isn't a "feature page" hero, it's a magazine cover. One
 * giant serif headline, a single italicized accent in klein orange, an
 * editorial folio in the corners, and just enough subtitle to land the
 * pitch. Two CTAs in mono caps. No badges, no cards, no chips.
 */
---

<section
  id="top"
  class="relative overflow-hidden border-b border-ink/15 bg-canvas"
  aria-label="claudex hero"
>
  <!-- Subtle grid + noise atmosphere -->
  <div class="absolute inset-0 bg-grid opacity-50 pointer-events-none"></div>
  <div class="absolute inset-0 bg-noise pointer-events-none"></div>

  <!-- Hairline accent — the only "ornament", a klein vertical that hints at column -->
  <div
    class="hidden lg:block absolute left-[max(2.5rem,calc((100vw-1440px)/2+2.5rem))] top-0 bottom-0 w-px bg-klein/40 fx-line delay-0"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-[1440px] mx-auto px-6 lg:px-10">
    <!-- Cover folio: top corner marks ------------------------------------ -->
    <div class="pt-10 lg:pt-14 grid grid-cols-2 items-start gap-4">
      <div class="flex flex-col gap-1 fx-fade delay-1">
        <span class="label text-ink">Vol. 1 · Issue 0</span>
        <span class="label-sm text-ink-muted">remote.claude / cockpit edition</span>
      </div>
      <div class="flex flex-col items-end text-right gap-1 fx-fade delay-1">
        <span class="label text-ink-muted">MIT · self-hosted</span>
        <span class="label-sm text-ink-muted">node 20 · pnpm 9</span>
      </div>
    </div>

    <!-- Cover headline ---------------------------------------------------- -->
    <div class="pt-16 pb-12 lg:pt-24 lg:pb-20">
      <h1 class="display leading-[0.86] tracking-[-0.045em] text-ink overflow-hidden">
        <span class="block fx-rise delay-2 text-[18vw] sm:text-[15vw] lg:text-[clamp(7rem,12vw,12rem)]">
          remote
        </span>
        <span
          class="block display-italic fx-rise delay-3 text-[18vw] sm:text-[15vw] lg:text-[clamp(7rem,12vw,12rem)] text-klein"
        >
          claude<span class="text-ink not-italic">.</span>
        </span>
      </h1>

      <!-- subtitle row, asymmetric -->
      <div class="mt-12 grid grid-cols-12 gap-x-6 gap-y-8 items-end">
        <div class="col-span-12 lg:col-span-6 lg:col-start-1 fx-fade delay-4">
          <p class="prose-serif text-[1.15rem] md:text-[1.4rem] leading-[1.45] tracking-[-0.005em] text-ink-soft max-w-[44ch]">
            Your <em class="display-italic text-klein">claude</em> is doing real work on your laptop.
            Open your phone, keep driving — review a diff, approve a permission, queue the next prompt.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-4 lg:col-start-9 fx-fade delay-4">
          <div class="border-t border-ink/30 pt-3 space-y-1.5">
            <div class="label text-ink">Fig. A — what it is</div>
            <p class="text-[12.5px] mono text-ink-muted leading-relaxed">
              A self-hosted browser for the<br/>
              <span class="text-ink">claude</span> CLI on your machine.<br/>
              Your keys. Your diffs. Your network.
            </p>
          </div>
        </div>
      </div>

      <!-- CTAs / cover marks -->
      <div class="mt-14 lg:mt-20 flex flex-wrap items-center gap-x-3 gap-y-4 fx-fade delay-5">
        <a href="/docs/installation" class="btn-ink">
          Install
          <span aria-hidden="true">→</span>
        </a>
        <a href="/docs" class="btn-ghost">Read the docs</a>
        <span class="hidden md:inline-block w-px h-5 bg-ink/20 mx-2"></span>
        <a
          href="https://github.com/ahaostudy/claudex"
          target="_blank"
          rel="noopener"
          class="btn-ghost"
        >
          GitHub <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>

    <!-- Bottom cover-strip — minimal facts, two columns -->
    <div class="border-t border-ink/15 py-5 grid grid-cols-2 md:grid-cols-4 gap-4 fx-fade delay-6">
      <div>
        <div class="label-sm text-ink-muted">Bind</div>
        <div class="mono text-[13px] text-ink mt-1">127.0.0.1 only</div>
      </div>
      <div>
        <div class="label-sm text-ink-muted">Auth</div>
        <div class="mono text-[13px] text-ink mt-1">password · TOTP</div>
      </div>
      <div>
        <div class="label-sm text-ink-muted">Inherits</div>
        <div class="mono text-[13px] text-ink mt-1">~/.claude/ config</div>
      </div>
      <div>
        <div class="label-sm text-ink-muted">Designed for</div>
        <div class="mono text-[13px] text-ink mt-1">390 px first</div>
      </div>
    </div>
  </div>
</section>
