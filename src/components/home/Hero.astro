---
/**
 * Hero — clean cover.
 *
 * A large brand mark up top, the wordmark "Claude𝑥." underneath, one
 * tight subtitle, three CTAs.
 */
import Logo from "~/components/Logo.astro";
import { getLocaleFromUrl, localizePath, type Locale } from "~/i18n/config";
import { useTranslations } from "~/i18n/ui";

interface Props {
  lang?: Locale;
}

const lang = Astro.props.lang ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="top"
  class="relative overflow-hidden border-b border-ink/15 bg-canvas min-h-screen min-h-[100svh] flex flex-col justify-center"
  aria-label="claudex hero"
>
  <!-- Subtle grid + noise atmosphere -->
  <div class="absolute inset-0 bg-grid opacity-50 pointer-events-none"></div>
  <div class="absolute inset-0 bg-noise pointer-events-none"></div>

  <div class="relative max-w-[1440px] mx-auto px-6 lg:px-10 w-full">
    <div class="py-12 lg:py-16">
      <!-- Logo + wordmark, side by side -->
      <div class="flex items-center gap-4 sm:gap-6 lg:gap-10 fx-rise delay-2">
        <Logo class="w-[17vw] h-[17vw] sm:w-[15vw] sm:h-[15vw] lg:w-[clamp(8rem,12vw,12rem)] lg:h-[clamp(8rem,12vw,12rem)] shrink-0" />
        <h1 class="display leading-[0.86] tracking-[-0.045em] text-ink overflow-hidden flex-1 min-w-0">
          <span class="block text-[18vw] sm:text-[16vw] lg:text-[clamp(7rem,13vw,13rem)]">
            Claude<span class="display-italic text-klein">x</span>
          </span>
        </h1>
      </div>

      <!-- subtitle -->
      <div class="mt-12 lg:mt-20 fx-fade delay-4">
        <p class="prose-serif text-[1.15rem] md:text-[1.4rem] leading-[1.5] tracking-[-0.005em] text-ink-soft max-w-[48ch]">
          {t("hero.subtitle.body")}
        </p>
      </div>

      <!-- CTAs -->
      <div class="mt-10 lg:mt-14 flex flex-wrap items-center gap-x-3 gap-y-4 fx-fade delay-5">
        <a href="#install" class="btn-ink">
          {t("hero.cta.install")}
          <span aria-hidden="true">↓</span>
        </a>
        <a href={localizePath("/docs", lang)} class="btn-ghost">{t("hero.cta.docs")}</a>
        <span class="hidden md:inline-block w-px h-5 bg-ink/20 mx-2"></span>
        <a
          href="https://github.com/ahaostudy/claudex"
          target="_blank"
          rel="noopener"
          class="btn-ghost"
        >
          {t("hero.cta.github")} <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </div>
</section>
