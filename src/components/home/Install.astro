---
---

<section id="install" class="border-b border-line bg-paper/40 relative overflow-hidden">
  <div class="absolute inset-0 bg-grid opacity-40 pointer-events-none"></div>
  <div class="relative max-w-[1280px] mx-auto px-5 lg:px-10 py-20 lg:py-24">
    <div class="flex items-baseline gap-4 mb-3 flex-wrap">
      <span class="mono text-[12px] text-ink-faint">section · 04</span>
      <h2 class="display text-[2rem] md:text-[2.4rem] leading-tight">Install in one line</h2>
    </div>
    <p class="max-w-[68ch] text-[15px] text-ink-muted">
      Prereqs: <span class="mono text-ink">node 20+</span>, <span class="mono text-ink">pnpm 9+</span>, and a working
      <span class="mono text-ink">claude</span> CLI you've already logged into. The installer checks for everything and
      offers to install anything missing.
    </p>

    <div class="mt-10 grid grid-cols-1 lg:grid-cols-2 gap-5">
      <article class="rounded-xl border border-line bg-canvas overflow-hidden">
        <header class="flex items-center justify-between px-4 py-2.5 border-b border-line">
          <div class="flex items-center gap-2">
            <span class="caps text-ink-muted">macOS / Linux</span>
            <span class="mono text-[10px] text-ink-faint">bash</span>
          </div>
          <button
            type="button"
            class="copy-btn h-7 px-2 rounded-md border border-line text-[11px] text-ink-soft hover:bg-paper inline-flex items-center gap-1.5"
            data-clipboard="curl -fsSL https://raw.githubusercontent.com/ahaostudy/claudex/main/install.sh | bash"
          >
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.7">
              <rect x="9" y="9" width="11" height="11" rx="2"></rect>
              <path d="M5 15V5a2 2 0 012-2h10" stroke-linecap="round"></path>
            </svg>
            <span class="copy-label">Copy</span>
          </button>
        </header>
        <pre class="m-0 p-4 bg-ink text-canvas mono text-[12.5px] leading-relaxed overflow-x-auto"><code><span class="text-ink-faint">$</span> curl -fsSL https://raw.githubusercontent.com/ahaostudy/claudex/main/install.sh | bash</code></pre>
        <div class="px-4 py-3 border-t border-line text-[12.5px] text-ink-muted leading-relaxed">
          Walks you through first-admin setup (username + password → TOTP QR → 10 one-shot recovery codes), then offers
          to register claudex as a user-scoped daemon: <span class="mono text-ink">launchd</span> on macOS,
          <span class="mono text-ink">systemd --user</span> on Linux.
        </div>
      </article>

      <article class="rounded-xl border border-line bg-canvas overflow-hidden">
        <header class="flex items-center justify-between px-4 py-2.5 border-b border-line">
          <div class="flex items-center gap-2">
            <span class="caps text-ink-muted">Windows</span>
            <span class="mono text-[10px] text-ink-faint">powershell</span>
          </div>
          <button
            type="button"
            class="copy-btn h-7 px-2 rounded-md border border-line text-[11px] text-ink-soft hover:bg-paper inline-flex items-center gap-1.5"
            data-clipboard="irm https://raw.githubusercontent.com/ahaostudy/claudex/main/install.ps1 | iex"
          >
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.7">
              <rect x="9" y="9" width="11" height="11" rx="2"></rect>
              <path d="M5 15V5a2 2 0 012-2h10" stroke-linecap="round"></path>
            </svg>
            <span class="copy-label">Copy</span>
          </button>
        </header>
        <pre class="m-0 p-4 bg-ink text-canvas mono text-[12.5px] leading-relaxed overflow-x-auto"><code><span class="text-ink-faint">PS&gt;</span> irm https://raw.githubusercontent.com/ahaostudy/claudex/main/install.ps1 | iex</code></pre>
        <div class="px-4 py-3 border-t border-line text-[12.5px] text-ink-muted leading-relaxed">
          Same flow as above. Daemon registration uses <span class="mono text-ink">pm2</span> +
          <span class="mono text-ink">pm2-windows-startup</span>, installed via npm if missing.
        </div>
      </article>
    </div>

    <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-4">
      <div class="rounded-lg border border-line bg-canvas p-4">
        <div class="caps text-ink-muted mb-1.5">step 01</div>
        <div class="display text-[1.1rem] leading-tight mb-1">Run the installer</div>
        <div class="text-[13px] text-ink-muted leading-relaxed">
          Every step is a prompt — nothing is silent, sudo is opt-in. Override location with <span class="mono text-ink">--dir</span>.
        </div>
      </div>
      <div class="rounded-lg border border-line bg-canvas p-4">
        <div class="caps text-ink-muted mb-1.5">step 02</div>
        <div class="display text-[1.1rem] leading-tight mb-1">Save your recovery codes</div>
        <div class="text-[13px] text-ink-muted leading-relaxed">
          Ten one-shot codes printed under a banner. Shown once, never again. Lose them and you're locked out.
        </div>
      </div>
      <div class="rounded-lg border border-line bg-canvas p-4">
        <div class="caps text-ink-muted mb-1.5">step 03</div>
        <div class="display text-[1.1rem] leading-tight mb-1">Open the URL on your phone</div>
        <div class="text-[13px] text-ink-muted leading-relaxed">
          The server binds to localhost. Front it with <a href="/docs/remote-access" class="text-klein-ink underline decoration-klein/40 hover:decoration-klein">Cloudflare Tunnel, frpc, or Tailscale</a>.
        </div>
      </div>
    </div>

    <div class="mt-10 flex items-center gap-3 flex-wrap">
      <a
        href="/docs/installation"
        class="inline-flex items-center gap-2 h-10 px-4 rounded-lg bg-ink text-canvas hover:bg-ink-soft text-[13.5px] font-medium transition-colors"
      >
        Full install guide
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <a href="/docs/first-run" class="inline-flex items-center gap-2 h-10 px-4 rounded-lg border border-line-strong bg-canvas hover:bg-paper text-[13.5px] text-ink-soft">
        First-run walkthrough
      </a>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-clipboard") || "";
      const label = btn.querySelector(".copy-label");
      const showCopied = () => {
        if (label) label.textContent = "Copied";
        setTimeout(() => {
          if (label) label.textContent = "Copy";
        }, 1400);
      };
      if (navigator.clipboard && window.isSecureContext) {
        try {
          await navigator.clipboard.writeText(text);
          showCopied();
          return;
        } catch (_) {
          /* fall through */
        }
      }
      // HTTP fallback (claudex is often served over plain HTTP via tunnel)
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.setAttribute("readonly", "");
      ta.style.position = "absolute";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      try {
        document.execCommand("copy");
        showCopied();
      } catch (_) {
        if (label) label.textContent = "Press ⌘C";
      }
      document.body.removeChild(ta);
    });
  });
</script>
