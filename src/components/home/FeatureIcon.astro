---
interface Props {
  name:
    | "layers"
    | "phone"
    | "shield"
    | "search"
    | "branch"
    | "key"
    | "fork"
    | "wave"
    | "clock"
    | "queue"
    | "terminal"
    | "spark";
}

const { name } = Astro.props;
const stroke = 1.6;
---

{
  name === "layers" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <path d="M12 3l9 5-9 5-9-5 9-5z" stroke-linejoin="round" />
      <path d="M3 13l9 5 9-5M3 18l9 5 9-5" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "phone" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <rect x="6" y="2.5" width="12" height="19" rx="2.5" />
      <path d="M11 18.5h2" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "shield" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <path d="M12 3l8 3v5c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z" stroke-linejoin="round" />
      <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "search" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <circle cx="11" cy="11" r="6.5" />
      <path d="M16 16l4 4" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "branch" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <circle cx="6" cy="5" r="2" />
      <circle cx="6" cy="19" r="2" />
      <circle cx="18" cy="9" r="2" />
      <path d="M6 7v10M6 14a8 8 0 008-8h2" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "key" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <circle cx="8" cy="14" r="4" />
      <path d="M11 13l9-9M16 8l3 3" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "fork" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <circle cx="6" cy="5" r="2" />
      <circle cx="18" cy="5" r="2" />
      <circle cx="12" cy="19" r="2" />
      <path d="M6 7v3a3 3 0 003 3h6a3 3 0 003-3V7M12 13v4" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "wave" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <path d="M3 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "clock" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "queue" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <path d="M4 7h16M4 12h12M4 17h16" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "terminal" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="M7 10l3 2-3 2M12 15h5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === "spark" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={stroke} class="w-4 h-4">
      <path
        d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5L18 18M6 18l2.5-2.5M15.5 8.5L18 6"
        stroke-linecap="round"
      />
    </svg>
  )
}
