---
import { getDocsNav } from "~/data/docs-nav";
import { getLocaleFromUrl, type Locale } from "~/i18n/config";
import { useTranslations } from "~/i18n/ui";

interface Props {
  current?: string;
  lang?: Locale;
}

const { current = "" } = Astro.props;
const lang = Astro.props.lang ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const docsNav = getDocsNav(lang);

const activeTitle = (() => {
  for (const section of docsNav) {
    for (const link of section.links) {
      if (link.href === current) return link.title;
    }
  }
  return null;
})();
---

<aside class="docs-sidebar">
  <details class="docs-toc">
    <summary class="docs-toc-summary">
      <span class="flex items-center gap-2 min-w-0">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4 h-4 shrink-0 text-ink-muted" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h10" stroke-linecap="round" />
        </svg>
        <span class="caps text-ink-muted">{t("docs.toc")}</span>
        {activeTitle ? (
          <>
            <span class="text-ink-faint" aria-hidden="true">/</span>
            <span class="text-[13px] font-medium text-ink truncate">{activeTitle}</span>
          </>
        ) : null}
      </span>
      <svg class="docs-toc-chev w-3.5 h-3.5 text-ink-muted shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </summary>
    <nav class="docs-toc-nav space-y-6 text-[13.5px]">
      {
        docsNav.map((section) => (
          <div>
            <div class="caps text-ink-muted mb-2 px-2">{section.label}</div>
            <ul class="space-y-0.5">
              {section.links.map((link) => {
                const isActive = link.href === current;
                return (
                  <li>
                    <a
                      href={link.href}
                      class={
                        "block px-2 py-1.5 rounded-md transition-colors " +
                        (isActive
                          ? "bg-klein-wash text-klein-ink font-medium border-l-2 border-klein -ml-[2px] pl-[10px]"
                          : "text-ink-soft hover:bg-paper hover:text-ink")
                      }
                    >
                      {link.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      }
    </nav>
  </details>
</aside>

<style>
  /* Desktop: classic sticky rail, no toggle UI */
  .docs-toc-summary {
    display: none;
  }
  .docs-toc > .docs-toc-nav {
    display: block;
  }

  /* Mobile: collapsible <details> with a visible summary chip */
  @media (max-width: 1023px) {
    .docs-toc-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      cursor: pointer;
      list-style: none;
      padding: 0.55rem 0.85rem;
      border: 1px solid rgb(var(--c-line));
      border-radius: 8px;
      background: rgb(var(--c-canvas));
      transition: background-color 140ms ease, border-color 140ms ease;
    }
    .docs-toc-summary::-webkit-details-marker {
      display: none;
    }
    .docs-toc-summary:hover {
      background: rgb(var(--c-paper));
      border-color: rgb(var(--c-line-strong));
    }
    .docs-toc-chev {
      transition: transform 180ms ease;
    }
    .docs-toc[open] .docs-toc-chev {
      transform: rotate(180deg);
    }
    .docs-toc[open] > .docs-toc-nav {
      display: block;
      padding: 0.85rem 0.25rem 0.25rem;
    }
    .docs-toc:not([open]) > .docs-toc-nav {
      display: none;
    }
  }
</style>
