---
import { getDocsNav } from "~/data/docs-nav";
import { getLocaleFromUrl, type Locale } from "~/i18n/config";

interface Props {
  current?: string;
  lang?: Locale;
}

const { current = "" } = Astro.props;
const lang = Astro.props.lang ?? getLocaleFromUrl(Astro.url);
const docsNav = getDocsNav(lang);
---

<aside class="docs-sidebar">
  <nav class="space-y-6 text-[13.5px]">
    {
      docsNav.map((section) => (
        <div>
          <div class="caps text-ink-muted mb-2 px-2">{section.label}</div>
          <ul class="space-y-0.5">
            {section.links.map((link) => {
              const isActive = link.href === current;
              return (
                <li>
                  <a
                    href={link.href}
                    class={
                      "block px-2 py-1.5 rounded-md transition-colors " +
                      (isActive
                        ? "bg-klein-wash text-klein-ink font-medium border-l-2 border-klein -ml-[2px] pl-[10px]"
                        : "text-ink-soft hover:bg-paper hover:text-ink")
                    }
                  >
                    {link.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>
